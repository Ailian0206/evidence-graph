{
  "name": "evidence-graph",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:local": "node --env-file-if-exists=.env.local scripts/local-development.mjs --profile=fixture",
    "dev:local:live": "node --env-file-if-exists=.env.local scripts/local-development.mjs --profile=live",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "check:provider-boundary": "node scripts/check-provider-boundary.mjs",
    "verify:managed-env": "node --env-file-if-exists=.env.local scripts/verify-managed-env.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "test:db": "supabase db reset --local && supabase test db --local && supabase db lint --local --level warning",
    "test:unit": "vitest run --passWithNoTests",
    "test:providers:live": "node --env-file-if-exists=.env.local ./node_modules/vitest/vitest.mjs run --config vitest.provider-smoke.config.ts",
    "test:e2e": "RESEARCH_PROVIDER_MODE=fixture npm run build && playwright test",
    "test:ci": "npm run lint && npm run typecheck && npm run test:unit && npm run test:e2e",
    "test:managed": "npm run check:provider-boundary && npm run test:db && npm run test:ci"
  },
  "engines": {
    "node": "22.x"
  },
  "overrides": {
    "postcss": "8.5.10"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.66.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.6",
    "@vercel/analytics": "^2.0.1",
    "cytoscape": "^3.34.0",
    "inngest": "^4.13.0",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "jsdom": "^29.1.1",
    "inngest-cli": "1.38.1",
    "supabase": "^2.109.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  }
}
